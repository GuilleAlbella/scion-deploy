# SCION deploy configuration. Copy to `.env` next to docker-compose.yml
# and edit values. Never commit the real `.env`.

# ──── Public-facing port (nginx) ────
SCION_PUBLIC_PORT=80

# ──── Image refs ────
# Default points at the public GHCR images. Override to pin to a
# specific release tag in production (recommended).
SCION_BACKEND_IMAGE=ghcr.io/guillealbella/scion-backend:latest
SCION_FRONTEND_IMAGE=ghcr.io/guillealbella/scion-frontend:latest

# ──── Region (purely informational for now; v1.23 makes it functional) ────
DATA_REGION=us-east-1

# ──── API authentication ────
# Strongly recommended in any non-local deployment. Generate with:
#   openssl rand -hex 32
# When set, every /api/v1/* endpoint requires `X-API-Key: <value>`.
# The frontend reads NEXT_PUBLIC_API_KEY at build time and includes it.
API_KEY=

# ──── AI provider (TAISA) ────
AI_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama3-70b-8192

# ──── Misc ────
LOG_LEVEL=info
TZ=UTC
