# Force LF line endings on shell scripts so they execute correctly on
# Linux even when committed from a Windows machine. Without this,
# Git's autocrlf would write CRLF and `#!/usr/bin/env bash` would fail
# with "bad interpreter: No such file or directory".
*.sh    text eol=lf
*.conf  text eol=lf
*.yml   text eol=lf

# Mark the .env template explicitly so it doesn't drift either.
.env.example text eol=lf
